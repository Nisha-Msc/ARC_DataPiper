# ArcDataPiper environment template
# Copy this file to .env and adjust values for your machine/runtime.

# Kafka / Redpanda
KAFKA_BROKERS=localhost:19092

# Service ports
HUB_PORT=3001
TRANSFORMER_PORT=3002
PRODUCER_PORT=3003

# Producer tuning
PRODUCER_INTERVAL_MS=500

# Cost model defaults (USD)
HEARTBEAT_COST=0.0001
DISCOVERY_COST=0.0010
FIXER_BOUNTY=0.0050
VERIFICATION_COST=0.0005

# LLM settings (required for auto-fix flow)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
